# Anthropic API Key for Claude (Level 1 and Production Mode)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Llama 3 Configuration (for Level 0)
# Default: http://localhost:11434/api/generate (Ollama default endpoint)
LLAMA_API_URL=http://localhost:11434/api/generate
LLAMA_MODEL=llama3

# Note: Make sure Ollama is installed and running
# Installation: https://ollama.ai
# Run: ollama run llama3

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback

# Jira OAuth 2.0 (3LO) — register at developer.atlassian.com
JIRA_CLIENT_ID=your_jira_client_id
JIRA_CLIENT_SECRET=your_jira_client_secret
# Must match exactly what is registered in the Atlassian app settings
JIRA_REDIRECT_URI=http://localhost:8000/api/jira/callback

# Frontend base URL (used to redirect back after OAuth callbacks)
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=43200